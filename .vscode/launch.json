        {
            "name": "Analyzer -COMPILED (prompts for path + input) [GENERIC]",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/Debug/nlp.exe",
            "args": [
                "-COMPILED",
                "-ANA", "${input:analyzerDir}",
                "-WORK", "${workspaceFolder}",
                "${input:inputFile}",
                "-DEV"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "preLaunchTask": "Build+Compile Analyzer (Debug, prompts)",
            "symbolOptions": {
                "searchPaths": [ "${input:analyzerDir}/bin" ],
                "searchMicrosoftSymbolServer": false
            },
            "sourceFileMap": {
                "${input:analyzerDir}/kb": "${input:analyzerDir}/kb"
            }
        },
        {
            "name": "Analyzer -COMPILE (prompts, debug engine emit)",
            "type": "cppvsdbg",
